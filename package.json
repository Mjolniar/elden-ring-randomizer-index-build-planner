{
  "name": "elden-ring-randomizer-index",
  "version": "1.4.1",
  "description": "Searchable spoiler-log index and build planner for Elden Ring Randomizer seeds.",
  "author": "Mjolniar",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "electron:dev": "concurrently -k -n vite,electron -c cyan,yellow \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "dist": "npm run build && electron-builder --win --x64 && npx tsx scripts/clean-release.ts"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "typescript": "^5.5.3",
    "vite": "^5.3.4",
    "vitest": "^2.0.5",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.mjolniar.eldenringrandomizer.buildplanner",
    "productName": "Elden Ring Randomizer Index and Build Planner",
    "copyright": "MIT",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "electron/main.js",
      "electron/preload.js",
      "package.json"
    ],
    "win": {
      "signAndEditExecutable": false,
      "icon": "assets/icon-randomizer.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "Elden Ring Randomizer Index",
      "artifactName": "${productName} ${version} Setup.${ext}",
      "runAfterFinish": false,
      "deleteAppDataOnUninstall": false
    }
  }
}
